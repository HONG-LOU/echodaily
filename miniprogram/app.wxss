page {
  --bg-base: #F5F5F7;
  --surface-card: #FFFFFF;
  --surface-soft: #F2F2F7;
  --ink-strong: #1D1D1F;
  --ink-base: #3A3A3C;
  --ink-soft: #86868B;
  --line-soft: rgba(60, 60, 67, 0.1);
  --accent-primary: #000000;
  
  height: 100vh;
  background: var(--bg-base);
  color: var(--ink-strong);
  font-family: -apple-system, BlinkMacSystemFont, "SF Pro Text", "Helvetica Neue", "PingFang SC", sans-serif;
}

view,
text,
button,
input,
textarea,
scroll-view {
  box-sizing: border-box;
}

.screen {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.page-shell {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 32rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  gap: 24rpx;
  overflow: hidden;
}

.glass-card {
  background: var(--surface-card);
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
  display: flex;
  flex-direction: column;
}

.eyebrow {
  color: var(--ink-soft);
  font-size: 22rpx;
  font-weight: 600;
  text-transform: uppercase;
  letter-spacing: 1rpx;
}

.section-kicker {
  display: block;
  color: var(--ink-soft);
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.section-title {
  display: block;
  font-size: 34rpx;
  line-height: 1.22;
  font-weight: 700;
  letter-spacing: -0.4rpx;
}

.section-subtitle {
  display: block;
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.58;
}

.title-xl {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--ink-strong);
  line-height: 1.2;
}

.title-md {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink-strong);
}

.subtitle {
  font-size: 26rpx;
  color: var(--ink-soft);
  line-height: 1.5;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip,
.pill {
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
  background: var(--surface-soft);
  color: var(--ink-base);
  font-size: 22rpx;
  font-weight: 500;
}

.primary-button,
.secondary-button,
.mini-button {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 100rpx;
  font-weight: 600;
  font-size: 28rpx;
  border: none;
}

.primary-button::after,
.secondary-button::after,
.mini-button::after {
  display: none;
}

.primary-button {
  background: var(--accent-primary);
  color: #FFFFFF;
  height: 88rpx;
}

.secondary-button {
  background: var(--surface-soft);
  color: var(--ink-strong);
  height: 88rpx;
}

.mini-button {
  background: var(--surface-soft);
  color: var(--ink-strong);
  height: 64rpx;
  font-size: 24rpx;
  padding: 0 24rpx;
}

.empty-state {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  gap: 16rpx;
}

.two-column-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}
