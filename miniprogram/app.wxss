page {
  --bg-top: #fbf7f2;
  --bg-base: #f4ede4;
  --bg-bottom: #efe5da;
  --surface-card: rgba(255, 252, 248, 0.82);
  --surface-strong: rgba(255, 254, 251, 0.94);
  --surface-soft: rgba(250, 243, 234, 0.72);
  --ink-strong: #251f19;
  --ink-base: #5c4d40;
  --ink-soft: #8d7c6c;
  --line-soft: rgba(92, 77, 64, 0.08);
  --line-strong: rgba(92, 77, 64, 0.14);
  --accent-peach: #efc8a7;
  --accent-amber: #dba56a;
  --accent-rose: #e8b4ab;
  --accent-sage: #c8d8ce;
  min-height: 100%;
  background:
    radial-gradient(circle at 12% 8%, rgba(244, 204, 168, 0.48), transparent 24%),
    radial-gradient(circle at 88% 14%, rgba(205, 222, 211, 0.44), transparent 24%),
    radial-gradient(circle at 50% 100%, rgba(255, 236, 219, 0.5), transparent 30%),
    linear-gradient(180deg, var(--bg-top) 0%, var(--bg-base) 48%, var(--bg-bottom) 100%);
  color: var(--ink-strong);
  font-family: "SF Pro Text", "SF Pro Display", "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
input,
textarea,
scroll-view {
  box-sizing: border-box;
}

.screen {
  height: 100vh;
}

.page-shell {
  position: relative;
  z-index: 0;
  min-height: 100%;
  padding: 32rpx 28rpx calc(164rpx + env(safe-area-inset-bottom));
}

.page-shell::before,
.page-shell::after {
  content: "";
  position: absolute;
  z-index: -1;
  border-radius: 50%;
  pointer-events: none;
}

.page-shell::before {
  top: 40rpx;
  left: -140rpx;
  width: 320rpx;
  height: 320rpx;
  background: radial-gradient(circle, rgba(240, 195, 158, 0.38), transparent 72%);
}

.page-shell::after {
  top: 280rpx;
  right: -120rpx;
  width: 280rpx;
  height: 280rpx;
  background: radial-gradient(circle, rgba(198, 217, 206, 0.34), transparent 72%);
}

.glass-card {
  position: relative;
  overflow: hidden;
  border-radius: 40rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  background: linear-gradient(180deg, var(--surface-strong) 0%, rgba(247, 239, 230, 0.78) 100%);
  box-shadow:
    0 20rpx 50rpx rgba(77, 59, 40, 0.08),
    inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.glass-card::after {
  content: "";
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.32), transparent 40%);
  pointer-events: none;
}

.section-block {
  margin-top: 28rpx;
}

.section-head {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 20rpx;
}

.section-head--stack {
  flex-direction: column;
  align-items: flex-start;
  gap: 8rpx;
  margin-bottom: 18rpx;
}

.eyebrow {
  display: inline-flex;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.56);
  color: var(--ink-soft);
  font-size: 20rpx;
  font-weight: 600;
  letter-spacing: 3rpx;
  text-transform: uppercase;
}

.section-kicker {
  display: block;
  color: var(--accent-amber);
  font-size: 22rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.section-title {
  display: block;
  font-size: 40rpx;
  line-height: 1.24;
  font-weight: 700;
  letter-spacing: -0.6rpx;
}

.section-subtitle {
  display: block;
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.72;
}

.title-xl {
  display: block;
  font-size: 60rpx;
  line-height: 1.14;
  font-weight: 700;
  letter-spacing: -1rpx;
}

.title-md {
  display: block;
  font-size: 38rpx;
  line-height: 1.3;
  font-weight: 700;
}

.subtitle {
  display: block;
  margin-top: 14rpx;
  color: var(--ink-soft);
  font-size: 26rpx;
  line-height: 1.8;
}

.chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip,
.pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.68);
  color: var(--ink-base);
  font-size: 22rpx;
  line-height: 1;
}

.pill {
  padding: 12rpx 20rpx;
  background: rgba(255, 255, 255, 0.78);
  color: var(--ink-soft);
}

.primary-button,
.secondary-button,
.mini-button {
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  border-radius: 999rpx;
  font-weight: 600;
}

.primary-button::after,
.secondary-button::after,
.mini-button::after {
  border: none;
}

.primary-button {
  min-height: 92rpx;
  padding: 0 34rpx;
  background: linear-gradient(180deg, #3b342d 0%, #231d18 100%);
  color: #fffaf5;
  font-size: 28rpx;
  box-shadow: 0 18rpx 30rpx rgba(51, 39, 29, 0.18);
}

.secondary-button {
  min-height: 92rpx;
  padding: 0 34rpx;
  background: rgba(255, 255, 255, 0.74);
  color: var(--ink-strong);
  font-size: 28rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.62);
}

.mini-button {
  min-height: 68rpx;
  padding: 0 24rpx;
  background: rgba(255, 255, 255, 0.72);
  color: var(--ink-strong);
  font-size: 24rpx;
}

.two-column-actions {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.bullet-list {
  margin-top: 18rpx;
}

.bullet-row {
  display: flex;
  align-items: flex-start;
  gap: 14rpx;
  margin-top: 16rpx;
}

.bullet-dot {
  width: 14rpx;
  height: 14rpx;
  margin-top: 12rpx;
  border-radius: 50%;
  background: linear-gradient(180deg, #edc192, #d8a16d);
}

.bullet-copy {
  flex: 1;
  color: var(--ink-base);
  font-size: 26rpx;
  line-height: 1.75;
}

.empty-state {
  padding: 52rpx 38rpx;
  text-align: center;
  color: var(--ink-soft);
  font-size: 26rpx;
  line-height: 1.8;
}

.soft-input,
.soft-textarea {
  width: 100%;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.74);
  border: 1rpx solid rgba(92, 77, 64, 0.08);
  color: var(--ink-strong);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.64);
}

.soft-input {
  min-height: 88rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.soft-textarea {
  min-height: 240rpx;
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  line-height: 1.72;
}

.soft-divider {
  height: 1rpx;
  margin: 24rpx 0 18rpx;
  background: rgba(92, 77, 64, 0.08);
}

.tip-text {
  color: var(--ink-soft);
  font-size: 22rpx;
  line-height: 1.75;
}
