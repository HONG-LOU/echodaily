<view class="screen">
  <view class="page-shell">
    <block wx:if="{{loading}}">
      <view class="glass-card loading-card">
        <text class="eyebrow">Profile</text>
        <text class="title-xl">准备中...</text>
      </view>
    </block>

    <block wx:elif="{{errorMessage}}">
      <view class="glass-card">
        <view class="empty-state">
          <text class="title-md">出错了</text>
          <text class="subtitle">{{errorMessage}}</text>
          <button class="primary-button" bindtap="handleRetry">重试</button>
        </view>
      </view>
    </block>

    <block wx:elif="{{profile}}">
      <!-- Profile Header -->
      <view class="glass-card profile-header">
        <view class="profile-top">
          <view class="avatar">{{profile.avatar_symbol}}</view>
          <view class="profile-info">
            <text class="title-xl">{{profile.nickname}}</text>
            <text class="subtitle">{{profile.city}} · {{profile.bio}}</text>
          </view>
        </view>
        
        <view class="chip-row">
          <text class="chip">重点音素 {{profile.weak_sound}}</text>
          <text class="chip">累计 {{profile.total_practices}} 次</text>
        </view>

        <view class="metrics-row">
          <view class="metric-item">
            <text class="metric-value">{{profile.streak_days}}</text>
            <text class="metric-label">连续天数</text>
          </view>
          <view class="metric-divider"></view>
          <view class="metric-item">
            <text class="metric-value">{{profile.weekly_minutes}}</text>
            <text class="metric-label">本周分钟</text>
          </view>
          <view class="metric-divider"></view>
          <view class="metric-item">
            <text class="metric-value">{{latestPractice ? latestPractice.score : '-'}}</text>
            <text class="metric-label">最新得分</text>
          </view>
        </view>
      </view>

      <!-- Spotlight Grid -->
      <view class="spotlight-grid">
        <view class="glass-card spotlight-card">
          <text class="eyebrow">发音重点</text>
          <block wx:if="{{topMistake}}">
            <text class="spotlight-title">{{topMistake.word}}</text>
            <text class="spotlight-subtitle">{{topMistake.expected_ipa}} · {{topMistake.score}}分</text>
            <text class="spotlight-desc">{{topMistake.coach_tip}}</text>
            <text class="spotlight-meta">{{topMistake.lesson_title}}</text>
          </block>
          <block wx:else>
            <text class="spotlight-title">状态不错</text>
            <text class="spotlight-desc">最近练习没有明显发音问题。</text>
          </block>
        </view>

        <view class="glass-card spotlight-card">
          <text class="eyebrow">最近一条</text>
          <block wx:if="{{latestPractice}}">
            <text class="spotlight-score">{{latestPractice.score}}</text>
            <text class="spotlight-desc">{{latestPractice.lesson_title}}</text>
            <text class="spotlight-meta">{{latestPractice.practiced_at}}</text>
            <button class="mini-button report-btn" bindtap="openRecentReport" data-assessment-id="{{latestPractice.assessment_id}}">打开报告</button>
          </block>
          <block wx:else>
            <text class="spotlight-title">暂无成绩</text>
            <text class="spotlight-desc">完成录音后会显示最新结果。</text>
          </block>
        </view>
      </view>

      <!-- Recent History -->
      <view class="glass-card history-card">
        <view class="history-header">
          <text class="eyebrow">最近两次</text>
          <text class="history-note">仅保留摘要</text>
        </view>
        
        <view class="history-list">
          <block wx:if="{{latestPractice}}">
            <view class="history-item" bindtap="openRecentReport" data-assessment-id="{{latestPractice.assessment_id}}">
              <view class="history-info">
                <text class="history-title">{{latestPractice.lesson_title}}</text>
                <text class="history-time">{{latestPractice.practiced_at}}</text>
              </view>
              <view class="history-score">{{latestPractice.score}}</view>
            </view>
          </block>
          <block wx:if="{{secondPractice}}">
            <view class="history-item" bindtap="openRecentReport" data-assessment-id="{{secondPractice.assessment_id}}">
              <view class="history-info">
                <text class="history-title">{{secondPractice.lesson_title}}</text>
                <text class="history-time">{{secondPractice.practiced_at}}</text>
              </view>
              <view class="history-score">{{secondPractice.score}}</view>
            </view>
          </block>
          <block wx:if="{{!latestPractice}}">
            <text class="empty-state-text">做完练习后，这里会保留最近报告。</text>
          </block>
        </view>
      </view>
    </block>
  </view>
</view>
