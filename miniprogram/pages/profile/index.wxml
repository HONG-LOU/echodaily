<scroll-view class="screen" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="page-shell profile-page">
    <block wx:if="{{loading}}">
      <view class="glass-card">
        <view class="empty-state">正在整理你的练习记录和错词重点。</view>
      </view>
    </block>

    <block wx:elif="{{errorMessage}}">
      <view class="glass-card">
        <view class="empty-state">
          <text class="subtitle">{{errorMessage}}</text>
          <button class="primary-button retry-button" bindtap="handleRetry">重新加载</button>
        </view>
      </view>
    </block>

    <block wx:elif="{{profile}}">
      <view class="glass-card profile-hero">
        <view class="profile-head">
          <view class="profile-avatar">{{profile.avatar_symbol}}</view>
          <view class="profile-copy">
            <text class="title-xl profile-title">{{profile.nickname}}</text>
            <text class="subtitle">{{profile.city}} · {{profile.bio}}</text>
          </view>
        </view>
        <view class="chip-row">
          <text class="chip">连续 {{profile.streak_days}} 天</text>
          <text class="chip">重点音素 {{profile.weak_sound}}</text>
        </view>
        <view class="profile-focus">
          <view class="profile-focus__item">
            <text class="profile-focus__label">累计练习</text>
            <text class="profile-focus__value">{{profile.total_practices}} 次</text>
          </view>
          <view class="profile-focus__item">
            <text class="profile-focus__label">本周时长</text>
            <text class="profile-focus__value">{{profile.weekly_minutes}} 分钟</text>
          </view>
        </view>
      </view>

      <view class="section-block">
        <view class="glass-card notebook-card">
          <view class="section-head section-head--stack">
            <text class="section-kicker">Notebook</text>
            <text class="section-title">错词记录</text>
            <text class="section-subtitle">把最近最需要处理的词先集中修正。</text>
          </view>
          <block wx:if="{{profile.mistake_notebook.length}}">
            <view class="notebook-item" wx:for="{{profile.mistake_notebook}}" wx:key="index">
              <view>
                <text class="notebook-word">{{item.word}}</text>
                <text class="notebook-ipa">{{item.expected_ipa}} · {{item.lesson_title}}</text>
                <text class="notebook-tip">{{item.coach_tip}}</text>
              </view>
              <text class="pill">{{item.score}} 分</text>
            </view>
          </block>
          <text class="section-subtitle" wx:else>最近的录音里还没有形成明显的错词积累。</text>
        </view>
      </view>

      <view class="section-block">
        <view class="glass-card recent-card">
          <text class="section-kicker">Recent</text>
          <text class="section-title">最近练习</text>
          <view
            class="recent-row"
            wx:for="{{profile.recent_practices}}"
            wx:key="assessment_id"
            bindtap="openRecentReport"
            data-assessment-id="{{item.assessment_id}}"
          >
            <view>
              <text class="recent-title">{{item.lesson_title}}</text>
              <text class="recent-time">{{item.practiced_at}}</text>
            </view>
            <text class="pill">{{item.score}} 分</text>
          </view>
        </view>
      </view>
    </block>
  </view>
</scroll-view>
