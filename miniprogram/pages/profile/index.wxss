.page-shell {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 32rpx;
  gap: 24rpx;
  overflow: hidden;
}

.profile-header {
  gap: 16rpx;
  flex-shrink: 0;
}

.profile-top {
  display: flex;
  align-items: flex-start;
  justify-content: flex-start;
  gap: 24rpx;
}

.profile-info {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex: 1;
  min-width: 0;
}

.profile-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.profile-name {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ink-strong);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  flex: 1;
}

.profile-bio {
  font-size: 24rpx;
  color: var(--ink-soft);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  background: var(--surface-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 600;
  color: var(--ink-strong);
  flex-shrink: 0;
}

.share-btn {
  height: 48rpx;
  padding: 0 20rpx;
  border-radius: 24rpx;
  background: var(--surface-soft);
  color: var(--ink-strong);
  font-size: 22rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  flex-shrink: 0;
}

.share-btn::after {
  display: none;
}

.metrics-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--surface-soft);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
  margin-top: 8rpx;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.metric-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink-strong);
}

.metric-label {
  font-size: 20rpx;
  color: var(--ink-soft);
}

.metric-divider {
  width: 2rpx;
  height: 40rpx;
  background: var(--line-soft);
}

.spotlight-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  flex-shrink: 0;
}

.spotlight-card {
  gap: 8rpx;
  min-height: 180rpx;
}

.spotlight-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ink-strong);
  margin-top: 8rpx;
}

.spotlight-subtitle {
  font-size: 24rpx;
  color: var(--ink-soft);
  font-weight: 500;
}

.spotlight-desc {
  font-size: 24rpx;
  color: var(--ink-strong);
  line-height: 1.4;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.spotlight-meta {
  font-size: 20rpx;
  color: var(--ink-soft);
  margin-top: auto;
}

.spotlight-score {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--ink-strong);
  line-height: 1;
  margin-top: 8rpx;
}

.report-btn {
  margin-top: auto;
}

.calendar-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
  min-height: 180rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.calendar-cell {
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
  background: var(--surface-soft);
}

.calendar-cell.active {
  background: var(--brand-primary);
}

.history-card {
  flex: 1;
  gap: 16rpx;
  display: flex;
  flex-direction: column;
  min-height: 180rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  flex-shrink: 0;
}

.history-note {
  font-size: 20rpx;
  color: var(--ink-soft);
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  overflow-y: auto;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx;
  background: var(--surface-soft);
  border-radius: 16rpx;
}

.history-info {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  flex: 1;
  min-width: 0;
}

.history-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--ink-strong);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.history-time {
  font-size: 20rpx;
  color: var(--ink-soft);
}

.history-score {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink-strong);
  background: var(--surface-card);
  padding: 8rpx 16rpx;
  border-radius: 100rpx;
  margin-left: 12rpx;
}

.empty-state-text {
  font-size: 24rpx;
  color: var(--ink-soft);
  text-align: center;
  padding: 40rpx 0;
}
