.page-shell {
  padding: 32rpx;
  gap: 24rpx;
}

.profile-header {
  padding: 40rpx 32rpx;
  gap: 24rpx;
}

.profile-top {
  display: flex;
  align-items: center;
  gap: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  background: var(--surface-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  font-weight: 600;
  color: var(--ink-strong);
}

.profile-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.metrics-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--surface-soft);
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
  margin-top: 8rpx;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.metric-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink-strong);
}

.metric-label {
  font-size: 22rpx;
  color: var(--ink-soft);
}

.metric-divider {
  width: 2rpx;
  height: 48rpx;
  background: var(--line-soft);
}

.spotlight-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.spotlight-card {
  padding: 32rpx 24rpx;
  gap: 12rpx;
  min-height: 240rpx;
}

.spotlight-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ink-strong);
  margin-top: 8rpx;
}

.spotlight-subtitle {
  font-size: 24rpx;
  color: var(--ink-soft);
  font-weight: 500;
}

.spotlight-desc {
  font-size: 24rpx;
  color: var(--ink-strong);
  line-height: 1.4;
  margin-top: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.spotlight-meta {
  font-size: 20rpx;
  color: var(--ink-soft);
  margin-top: auto;
}

.spotlight-score {
  font-size: 64rpx;
  font-weight: 700;
  color: var(--ink-strong);
  line-height: 1;
  margin-top: 8rpx;
}

.report-btn {
  margin-top: auto;
}

.calendar-card {
  padding: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.calendar-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.calendar-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.calendar-cell {
  width: 24rpx;
  height: 24rpx;
  border-radius: 4rpx;
  background: var(--surface-soft);
}

.calendar-cell.active {
  background: var(--brand-primary);
}

.history-card {
  flex: 1;
  padding: 32rpx;
  gap: 24rpx;
}

.history-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.history-note {
  font-size: 22rpx;
  color: var(--ink-soft);
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.history-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  background: var(--surface-soft);
  border-radius: 24rpx;
}

.history-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
  min-width: 0;
}

.history-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--ink-strong);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.history-time {
  font-size: 22rpx;
  color: var(--ink-soft);
}

.history-score {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink-strong);
  background: var(--surface-card);
  padding: 12rpx 24rpx;
  border-radius: 100rpx;
  margin-left: 16rpx;
}

.empty-state-text {
  font-size: 24rpx;
  color: var(--ink-soft);
  text-align: center;
  padding: 40rpx 0;
}
