.report-page {
  padding: 32rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  gap: 0;
}

.report-scroll {
  flex: 1;
  min-height: 0;
  width: 100%;
}

.scroll-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding-bottom: 24rpx;
}

.score-card {
  padding: 40rpx 32rpx;
  gap: 32rpx;
}

.score-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.score-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.score-caption {
  font-size: 24rpx;
  color: var(--ink-soft);
  font-weight: 500;
}

.score-shell {
  display: flex;
  align-items: center;
  gap: 32rpx;
}

.score-bubble {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background: var(--surface-soft);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  border: 4rpx solid var(--line-soft);
}

.score-value {
  font-size: 56rpx;
  font-weight: 700;
  color: var(--ink-strong);
  line-height: 1;
}

.score-label {
  font-size: 22rpx;
  color: var(--ink-soft);
  margin-top: 8rpx;
}

.score-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.recognized-copy {
  font-size: 24rpx;
  color: var(--ink-soft);
  line-height: 1.5;
  background: var(--surface-soft);
  padding: 24rpx;
  border-radius: 24rpx;
}

.summary-metrics {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.summary-metric {
  background: var(--surface-soft);
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.summary-metric__label {
  font-size: 22rpx;
  color: var(--ink-soft);
}

.summary-metric__value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink-strong);
}

.breakdown-card {
  padding: 40rpx 32rpx;
  gap: 24rpx;
}

.section-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.section-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.section-subtitle {
  font-size: 24rpx;
  color: var(--ink-soft);
}

.dimension-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32rpx 24rpx;
  margin-top: 8rpx;
}

.dimension-card {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.dimension-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
}

.dimension-label {
  font-size: 24rpx;
  color: var(--ink-strong);
  font-weight: 500;
}

.dimension-score {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink-strong);
  line-height: 1;
}

.dimension-track {
  height: 12rpx;
  background: var(--surface-soft);
  border-radius: 6rpx;
  overflow: hidden;
}

.dimension-fill {
  height: 100%;
  background: var(--accent-primary);
  border-radius: 6rpx;
}

.highlight-card {
  padding: 40rpx 32rpx;
  gap: 24rpx;
}

.highlight-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.highlight-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.highlight-item {
  background: var(--surface-soft);
  border-radius: 24rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.highlight-item--high {
  background: #FFF5F5;
}

.highlight-item--medium {
  background: #FFF9F0;
}

.highlight-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.highlight-copy {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.highlight-word {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink-strong);
}

.highlight-issue {
  font-size: 24rpx;
  color: var(--ink-strong);
  line-height: 1.4;
}

.highlight-score {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink-strong);
  background: var(--surface-card);
  padding: 8rpx 20rpx;
  border-radius: 100rpx;
}

.highlight-tips {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  background: rgba(255, 255, 255, 0.5);
  padding: 16rpx;
  border-radius: 16rpx;
}

.highlight-tip {
  font-size: 22rpx;
  color: var(--ink-soft);
  line-height: 1.4;
}

.empty-state-text {
  font-size: 26rpx;
  color: var(--ink-soft);
  text-align: center;
  padding: 32rpx 0;
}

.bottom-actions {
  display: grid;
  grid-template-columns: 1fr 1fr 1fr;
  gap: 16rpx;
  padding-top: 16rpx;
}
