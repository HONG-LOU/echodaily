.report-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.retry-button,
.home-button {
  margin-top: 24rpx;
}

.score-card,
.radar-card,
.highlight-card,
.poster-card {
  padding: 32rpx;
}

.score-card {
  background: linear-gradient(160deg, rgba(255, 253, 250, 0.96), rgba(246, 236, 226, 0.86));
}

.score-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.score-caption {
  display: block;
  margin-top: 14rpx;
  color: var(--ink-soft);
  font-size: 24rpx;
}

.score-shell {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-top: 24rpx;
}

.score-bubble {
  width: 188rpx;
  height: 188rpx;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: radial-gradient(circle at 50% 40%, #fffdf9, #f2e2d1 70%, #ebcfb0 100%);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.score-value {
  display: block;
  font-size: 66rpx;
  font-weight: 700;
}

.score-label {
  display: block;
  margin-top: 8rpx;
  color: var(--ink-soft);
  font-size: 22rpx;
}

.score-copy {
  flex: 1;
}

.summary-metrics {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 26rpx;
}

.summary-metric {
  padding: 22rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.62);
}

.summary-metric__label {
  display: block;
  color: var(--ink-soft);
  font-size: 22rpx;
}

.summary-metric__value {
  display: block;
  margin-top: 12rpx;
  font-size: 32rpx;
  font-weight: 700;
}

.radar-canvas {
  width: 560rpx;
  height: 560rpx;
  margin: 24rpx auto 10rpx;
}

.dimension-list {
  margin-top: 14rpx;
}

.dimension-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 18rpx;
}

.dimension-label {
  width: 110rpx;
  color: var(--ink-base);
  font-size: 24rpx;
}

.dimension-track {
  flex: 1;
  height: 18rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: rgba(123, 111, 101, 0.12);
}

.dimension-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #e1af7e, #efc8a7);
}

.dimension-score {
  width: 56rpx;
  text-align: right;
  font-size: 24rpx;
  font-weight: 600;
}

.highlight-item {
  margin-top: 20rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: rgba(255, 255, 255, 0.62);
  border: 1rpx solid rgba(255, 255, 255, 0.48);
}

.highlight-item--high {
  background: linear-gradient(135deg, rgba(255, 245, 240, 0.9), rgba(255, 233, 226, 0.72));
}

.highlight-item--medium {
  background: linear-gradient(135deg, rgba(255, 250, 244, 0.88), rgba(248, 240, 229, 0.72));
}

.highlight-item--low {
  background: linear-gradient(135deg, rgba(251, 252, 249, 0.88), rgba(238, 244, 239, 0.72));
}

.highlight-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  align-items: flex-start;
}

.highlight-word {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
}

.highlight-issue {
  display: block;
  margin-top: 10rpx;
  color: var(--ink-base);
  font-size: 24rpx;
  line-height: 1.72;
}

.highlight-tip,
.poster-caption,
.poster-translation {
  display: block;
  margin-top: 10rpx;
  color: var(--ink-soft);
  font-size: 24rpx;
  line-height: 1.75;
}

.highlight-severity {
  display: inline-flex;
  margin-top: 16rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.58);
  color: var(--ink-base);
  font-size: 22rpx;
}

.poster-card {
  min-height: 380rpx;
  padding: 34rpx 32rpx;
}

.poster-theme--cream-sky {
  background: linear-gradient(180deg, rgba(255, 252, 248, 0.98), rgba(246, 237, 227, 0.9));
}

.poster-theme--peach-rose {
  background: linear-gradient(180deg, rgba(255, 247, 243, 0.98), rgba(251, 228, 224, 0.9));
}

.poster-theme--mint-latte {
  background: linear-gradient(180deg, rgba(252, 253, 249, 0.98), rgba(228, 241, 235, 0.92));
}

.poster-quote {
  display: block;
  margin-top: 28rpx;
  font-size: 40rpx;
  line-height: 1.62;
  font-weight: 600;
}

.poster-footer {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 26rpx;
}
