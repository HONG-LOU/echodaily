.page-shell {
  padding: 32rpx;
  gap: 24rpx;
}

.header-card {
  padding: 40rpx 32rpx;
  gap: 32rpx;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.header-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 48rpx;
  background: var(--surface-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  font-weight: 600;
  color: var(--ink-strong);
}

.metrics-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--surface-soft);
  border-radius: 24rpx;
  padding: 24rpx 32rpx;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.metric-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink-strong);
}

.metric-label {
  font-size: 22rpx;
  color: var(--ink-soft);
}

.metric-divider {
  width: 2rpx;
  height: 48rpx;
  background: var(--line-soft);
}

.lesson-swiper {
  flex: 1;
  width: 100%;
  height: 600rpx;
}

.lesson-card {
  height: 100%;
  box-sizing: border-box;
  padding: 40rpx 32rpx;
  gap: 16rpx;
  display: flex;
  flex-direction: column;
}

.lesson-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.lesson-pack {
  font-size: 22rpx;
  color: var(--ink-soft);
  font-weight: 600;
  text-transform: uppercase;
}

.lesson-time {
  font-size: 22rpx;
  color: var(--ink-soft);
}

.lesson-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ink-strong);
  margin-bottom: 8rpx;
}

.lesson-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink-strong);
  line-height: 1.4;
  margin-bottom: 4rpx;
}

.lesson-translation {
  font-size: 24rpx;
  color: var(--ink-soft);
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.audio-action {
  margin-bottom: 12rpx;
  display: flex;
  justify-content: flex-start;
}

.lesson-hint {
  margin-top: auto;
  background: var(--surface-soft);
  border-radius: 24rpx;
  padding: 24rpx;
}

.hint-label {
  font-size: 20rpx;
  color: var(--ink-soft);
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.hint-text {
  font-size: 24rpx;
  color: var(--ink-strong);
  line-height: 1.4;
}

.bottom-section {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.status-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.status-card {
  background: var(--surface-card);
  border-radius: 32rpx;
  padding: 24rpx 32rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.status-label {
  font-size: 22rpx;
  color: var(--ink-soft);
}

.status-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink-strong);
}

.action-buttons {
  margin-top: 8rpx;
}
