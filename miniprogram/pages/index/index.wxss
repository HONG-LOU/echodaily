.page-shell {
  flex: 1;
  display: flex;
  flex-direction: column;
  padding: 32rpx;
  gap: 24rpx;
  overflow: hidden;
}

.header-card {
  gap: 24rpx;
  flex-shrink: 0;
}

.header-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
}

.header-info {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  flex: 1;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 40rpx;
  background: var(--surface-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink-strong);
}

.metrics-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: var(--surface-soft);
  border-radius: 20rpx;
  padding: 20rpx 24rpx;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4rpx;
}

.metric-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--ink-strong);
}

.metric-label {
  font-size: 20rpx;
  color: var(--ink-soft);
}

.metric-divider {
  width: 2rpx;
  height: 40rpx;
  background: var(--line-soft);
}

.lesson-swiper {
  flex: 1;
  min-height: 0;
  width: 100%;
}

.lesson-card {
  height: 100%;
  box-sizing: border-box;
  gap: 12rpx;
  display: flex;
  flex-direction: column;
}

.lesson-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.lesson-pack {
  font-size: 22rpx;
  color: var(--ink-soft);
  font-weight: 600;
  text-transform: uppercase;
}

.lesson-time {
  font-size: 22rpx;
  color: var(--ink-soft);
}

.lesson-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ink-strong);
  margin-bottom: 8rpx;
}

.lesson-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--ink-strong);
  line-height: 1.4;
  margin-bottom: 4rpx;
}

.lesson-translation {
  font-size: 24rpx;
  color: var(--ink-soft);
  line-height: 1.5;
  margin-bottom: 12rpx;
}

.audio-action {
  margin-bottom: 12rpx;
  display: flex;
  justify-content: flex-start;
}

.swipe-guide {
  margin-top: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  min-height: 88rpx;
}

.swipe-guide-text {
  font-size: 22rpx;
  color: var(--ink-soft);
}

.swipe-dots {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.swipe-dot {
  width: 10rpx;
  height: 10rpx;
  border-radius: 50%;
  background: rgba(120, 127, 140, 0.35);
}

.swipe-dot-active {
  background: var(--ink-strong);
}

.bottom-section {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  flex-shrink: 0;
}

.status-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.status-card {
  background: var(--surface-card);
  border-radius: 24rpx;
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.04);
}

.status-label {
  font-size: 22rpx;
  color: var(--ink-soft);
}

.status-value {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--ink-strong);
}

.action-buttons {
  margin-top: 8rpx;
}
