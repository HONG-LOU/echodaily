<view class="screen">
  <view class="page-shell">
    <block wx:if="{{loading}}">
      <view class="glass-card loading-card">
        <text class="eyebrow">EchoDaily</text>
        <text class="title-xl">准备中...</text>
      </view>
    </block>

    <block wx:elif="{{errorMessage}}">
      <view class="glass-card">
        <view class="empty-state">
          <text class="title-md">出错了</text>
          <text class="subtitle">{{errorMessage}}</text>
          <button class="primary-button" bindtap="handleRetry">重试</button>
        </view>
      </view>
    </block>

    <block wx:elif="{{dashboard}}">
      <!-- Header Card -->
      <view class="glass-card header-card">
        <view class="header-top">
          <view class="header-info">
            <text class="eyebrow">TODAY</text>
            <text class="title-xl">今天继续开口</text>
            <text class="subtitle">{{dashboard.user.nickname}}，{{dashboard.daily_message}}</text>
          </view>
          <view class="avatar">{{dashboard.user.avatar_symbol}}</view>
        </view>
        
        <view class="metrics-row">
          <view class="metric-item">
            <text class="metric-value">{{dashboard.user.streak_days}}</text>
            <text class="metric-label">连续天数</text>
          </view>
          <view class="metric-divider"></view>
          <view class="metric-item">
            <text class="metric-value">{{dashboard.user.weekly_minutes}}</text>
            <text class="metric-label">本周分钟</text>
          </view>
          <view class="metric-divider"></view>
          <view class="metric-item">
            <text class="metric-value">{{dashboard.user.total_practices}}</text>
            <text class="metric-label">累计次数</text>
          </view>
        </view>
      </view>

      <!-- Lesson Card -->
      <view class="glass-card lesson-card">
        <view class="lesson-header">
          <text class="lesson-pack">{{dashboard.today_lesson.pack_name}}</text>
          <text class="lesson-time">{{dashboard.today_lesson.estimated_seconds}}秒精练</text>
        </view>
        
        <text class="lesson-title">{{dashboard.today_lesson.title}}</text>
        <text class="lesson-text">{{dashboard.today_lesson.english_text}}</text>
        <text class="lesson-translation">{{dashboard.today_lesson.translation}}</text>
        
        <view class="chip-row">
          <block wx:for="{{dashboard.today_lesson.tags}}" wx:key="*this" wx:for-index="index">
            <text class="chip" wx:if="{{index < 3}}">{{item}}</text>
          </block>
        </view>

        <view class="lesson-hint">
          <text class="hint-label">提示</text>
          <text class="hint-text">{{dashboard.today_lesson.mode_hint}}</text>
        </view>
      </view>

      <!-- Actions & Status -->
      <view class="bottom-section">
        <view class="status-cards">
          <view class="status-card">
            <text class="status-label">发音重点</text>
            <text class="status-value">{{dashboard.user.weak_sound}}</text>
          </view>
          <view class="status-card">
            <text class="status-label">今日状态</text>
            <text class="status-value">{{latestScore ? latestScore.overall_score + '分' : '待练习'}}</text>
          </view>
        </view>
        
        <view class="action-buttons {{latestScore ? 'two-column-actions' : ''}}">
          <button class="primary-button" bindtap="startPractice" data-lesson-id="{{dashboard.today_lesson.id}}">开始录音</button>
          <button wx:if="{{latestScore}}" class="secondary-button" bindtap="openRecentReport" data-assessment-id="{{latestScore.assessment_id}}">查看报告</button>
        </view>
      </view>
    </block>
  </view>
</view>
