<scroll-view class="screen" scroll-y enhanced show-scrollbar="{{false}}">
  <view class="page-shell challenge-page">
    <view class="glass-card challenge-hero">
      <view class="hero-glow hero-glow--peach"></view>
      <view class="hero-glow hero-glow--sage"></view>
      <text class="eyebrow">21 Day Club</text>
      <text class="title-xl challenge-title">把打卡变成一件有回报的事</text>
      <text class="subtitle challenge-subtitle">挑战营负责把“想练”变成“练下去”，再给坚持一点现实奖励。</text>
      <view class="challenge-hero__metrics">
        <view class="challenge-hero__item">
          <text class="challenge-hero__label">当前活动</text>
          <text class="challenge-hero__value">{{challenges.length || 1}} 个</text>
        </view>
        <view class="challenge-hero__item">
          <text class="challenge-hero__label">设计目标</text>
          <text class="challenge-hero__value">更稳的参与感</text>
        </view>
      </view>
    </view>

    <block wx:if="{{loading}}">
      <view class="glass-card">
        <view class="empty-state">正在拉取挑战营和共学信息。</view>
      </view>
    </block>

    <block wx:elif="{{errorMessage}}">
      <view class="glass-card">
        <view class="empty-state">
          <text class="subtitle">{{errorMessage}}</text>
          <button class="primary-button retry-button" bindtap="handleRetry">重新加载</button>
        </view>
      </view>
    </block>

    <block wx:else>
      <view class="challenge-list">
        <view class="glass-card challenge-card" wx:for="{{challenges}}" wx:key="id">
          <view class="challenge-card__top">
            <view>
              <text class="section-kicker">Day {{item.days_total}}</text>
              <text class="section-title">{{item.title}}</text>
            </view>
            <text class="pill">剩余 {{item.days_left}} 天</text>
          </view>
          <text class="challenge-desc">{{item.description}}</text>
          <view class="challenge-progress">
            <view class="challenge-progress__track">
              <view
                class="challenge-progress__fill"
                style="width: {{item.days_total ? ((item.days_total - item.days_left) / item.days_total) * 100 : 0}}%;"
              ></view>
            </view>
            <text class="challenge-progress__copy">已进行 {{item.days_total - item.days_left}} / {{item.days_total}} 天</text>
          </view>
          <view class="challenge-metrics">
            <view class="metric-chip">
              <text class="metric-chip__value">{{item.participants}}</text>
              <text class="metric-chip__label">参与人数</text>
            </view>
            <view class="metric-chip">
              <text class="metric-chip__value">¥{{item.deposit_amount}}</text>
              <text class="metric-chip__label">契约金</text>
            </view>
            <view class="metric-chip">
              <text class="metric-chip__value">¥{{item.reward_pool}}</text>
              <text class="metric-chip__label">奖金池</text>
            </view>
            <view class="metric-chip">
              <text class="metric-chip__value">{{item.score_threshold}}</text>
              <text class="metric-chip__label">每日达标分</text>
            </view>
          </view>
          <text class="challenge-note">{{item.teaser}}</text>
          <button class="primary-button" bindtap="joinChallenge" data-title="{{item.title}}">
            立即加入体验
          </button>
        </view>
      </view>

      <view class="glass-card strategy-card">
        <text class="section-kicker">How It Works</text>
        <text class="section-title">运营落地建议</text>
        <text class="section-subtitle">别让挑战营像活动页，更像一个让人愿意留下来的小社区。</text>
        <view class="strategy-list">
          <view class="strategy-row">
            <view class="strategy-badge">01</view>
            <view class="strategy-copy">
              <text class="strategy-title">先抓中腰部英语学习者</text>
              <text class="strategy-body">用“每天一条可完成的开口任务”切入，他们最在意的是能不能坚持和能不能看见变化。</text>
            </view>
          </view>
          <view class="strategy-row">
            <view class="strategy-badge">02</view>
            <view class="strategy-copy">
              <text class="strategy-title">内容包做得更垂直</text>
              <text class="strategy-body">优先外企表达、电影台词、晨读跟读这些更适合传播的主题，让用户一眼知道自己练什么。</text>
            </view>
          </view>
          <view class="strategy-row">
            <view class="strategy-badge">03</view>
            <view class="strategy-copy">
              <text class="strategy-title">把会员价值放在错词和复练</text>
              <text class="strategy-body">免费用户先看到分数和趋势，详细纠音、专项复练和长期错题本作为自然升级点。</text>
            </view>
          </view>
        </view>
      </view>
    </block>
  </view>
</scroll-view>
