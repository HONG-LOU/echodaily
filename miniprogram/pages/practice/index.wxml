<view class="screen">
  <view class="page-shell">
    <block wx:if="{{loading}}">
      <view class="glass-card loading-card">
        <text class="eyebrow">Practice</text>
        <text class="title-xl">准备中...</text>
      </view>
    </block>

    <block wx:elif="{{errorMessage}}">
      <view class="glass-card">
        <view class="empty-state">
          <text class="title-md">出错了</text>
          <text class="subtitle">{{errorMessage}}</text>
          <button class="primary-button" bindtap="handleRetry">重试</button>
        </view>
      </view>
    </block>

    <block wx:elif="{{lesson}}">
      <view class="glass-card practice-card">
        <view class="practice-header">
          <text class="eyebrow">{{lesson.pack_name}}</text>
          <text class="pill">{{lesson.estimated_seconds}}秒</text>
        </view>
        
        <text class="title-md">{{lesson.title}}</text>
        <text class="subtitle">{{lesson.subtitle}}</text>

        <view class="script-section">
          <text class="script-english">{{lesson.english_text}}</text>
          <text class="script-translation">{{lesson.translation}}</text>
        </view>

        <view class="chip-row">
          <block wx:for="{{lesson.tags}}" wx:key="*this" wx:for-index="index">
            <text class="chip" wx:if="{{index < 2}}">{{item}}</text>
          </block>
          <text class="chip">{{lesson.scenario}}</text>
        </view>

        <view class="script-note">
          <text class="note-label">提示</text>
          <text class="note-text">{{lesson.mode_hint}}</text>
        </view>

        <view class="recorder-section">
          <view class="recorder-status">
            <text class="status-badge">{{tempFilePath ? '已录制' : '未录制'}}</text>
          </view>

          <view class="recorder-ring {{recording ? 'recorder-ring--active' : ''}}">
            <text class="ring-time">{{recordedDuration ? recordedDuration + 's' : lesson.estimated_seconds + 's'}}</text>
            <text class="ring-label">{{recording ? '录音中' : tempFilePath ? '已完成' : '目标时长'}}</text>
          </view>

          <view class="recorder-actions">
            <view class="two-column-actions">
              <button class="primary-button" wx:if="{{!recording}}" bindtap="startRecording">开始录音</button>
              <button class="primary-button" wx:else bindtap="stopRecording">结束录音</button>
              <button class="secondary-button" bindtap="playRecording" disabled="{{!tempFilePath}}">回放录音</button>
            </view>
          </view>

          <view class="footer-actions">
            <button class="mini-button" bindtap="previewHint">完整提示</button>
            <button class="primary-button submit-btn" bindtap="submitAssessment" loading="{{submitting}}">生成报告</button>
          </view>
        </view>
      </view>
    </block>
  </view>
</view>
