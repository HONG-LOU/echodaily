.page-shell {
  padding: 32rpx 32rpx calc(48rpx + env(safe-area-inset-bottom));
  gap: 0;
}

.practice-card {
  flex: 1;
  gap: 24rpx;
  overflow-y: auto;
}

.practice-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.script-section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
  background: var(--surface-soft);
  padding: 32rpx;
  border-radius: 24rpx;
}

.script-english {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--ink-strong);
  line-height: 1.4;
}

.script-translation {
  font-size: 26rpx;
  color: var(--ink-soft);
  line-height: 1.5;
}

.audio-action {
  margin-top: 24rpx;
  display: flex;
  justify-content: flex-start;
}

.script-note {
  margin-top: 16rpx;
  background: var(--surface-soft);
  border-radius: 24rpx;
  padding: 24rpx;
}

.note-label {
  font-size: 20rpx;
  color: var(--ink-soft);
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.note-text {
  font-size: 24rpx;
  color: var(--ink-strong);
  line-height: 1.4;
}

.recorder-section {
  margin-top: auto;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 32rpx;
}

.recorder-status {
  display: flex;
  gap: 16rpx;
}

.status-badge {
  padding: 8rpx 24rpx;
  border-radius: 100rpx;
  background: var(--surface-soft);
  color: var(--ink-base);
  font-size: 22rpx;
  font-weight: 500;
}

.recorder-ring {
  width: 240rpx;
  height: 240rpx;
  border-radius: 120rpx;
  background: var(--surface-soft);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border: 4rpx solid var(--line-soft);
  transition: all 0.3s ease;
}

.recorder-ring--active {
  background: #FFE5E5;
  border-color: #FF3B30;
  transform: scale(1.05);
}

.ring-time {
  font-size: 48rpx;
  font-weight: 700;
  color: var(--ink-strong);
}

.ring-label {
  font-size: 24rpx;
  color: var(--ink-soft);
}

.recorder-actions {
  width: 100%;
}

.footer-actions {
  width: 100%;
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.submit-btn {
  flex: 1;
}
